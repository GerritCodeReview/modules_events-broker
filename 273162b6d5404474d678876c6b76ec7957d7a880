    },
    {
      "unresolved": false,
      "key": {
        "uuid": "bc063d33_0632feee",
        "filename": "src/main/java/com/gerritforge/gerrit/eventbroker/BrokerApi.java",
        "patchSetId": 11
      },
      "lineNbr": 88,
      "author": {
        "id": 1072905
      },
      "writtenOn": "2026-02-27T15:36:09Z",
      "side": 1,
      "message": "After a f2f conversation, we agreed that since this is a master, it is acceptable to implement a change that is not backwards compatible.\n\nBroker Api implementations that want to consume this events-broker library will need to adapt to this new interface.\n\nResolving this.",
      "parentUuid": "3a16ef2f_cba49cde",
      "range": {
        "startLine": 86,
        "startChar": 0,
        "endLine": 88,
        "endChar": 5
